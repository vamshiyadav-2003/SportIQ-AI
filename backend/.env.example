# Rename this file to .env and fill in your own keys before running the backend

# Groq LLM API key - https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Tavily web search API key - https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Chroma persistent storage location (relative to backend/)
CHROMA_DB_PATH=./chroma_store

# Embedding model used to build the vector store
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
